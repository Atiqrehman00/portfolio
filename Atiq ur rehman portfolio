*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI;
}

body{
background:#0f172a;
color:white;
line-height:1.6;
transition:0.4s;
}

.light{
background:#f4f4f4;
color:#222;
}

/* NAVBAR */

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 40px;
background:#020617;
position:sticky;
top:0;
}

.logo{
font-size:22px;
